{
  "name": "dotreadme",
  "displayName": "DotReadme",
  "description": "The ultimate README optimizer for VS Code Marketplace, GitHub, and Open VSX Registry.",
  "version": "1.1.0",
  "publisher": "FreeRave",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/kareem2099/DotReadme.git"
  },
  "engines": {
    "vscode": "^1.108.1"
  },
  "categories": [
    "Visualization",
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "DotReadme",
      "properties": {
        "dotreadme.ai.provider": {
          "type": "string",
          "enum": ["anthropic", "openai", "gemini"],
          "default": "anthropic",
          "description": "The AI provider to use for README enhancements.",
          "enumDescriptions": [
            "Use Anthropic Claude API",
            "Use OpenAI GPT API",
            "Use Google Gemini API"
          ]
        },
        "dotreadme.ai.anthropicApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Your Anthropic API Key. Get one at [console.anthropic.com](https://console.anthropic.com). **Never share this key.**",
          "secret": true
        },
        "dotreadme.ai.openaiApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Your OpenAI API Key. Get one at [platform.openai.com](https://platform.openai.com). **Never share this key.**",
          "secret": true
        },
        "dotreadme.ai.geminiApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Your Google Gemini API Key. Get one at [aistudio.google.com](https://aistudio.google.com/app/apikey). **Never share this key.**",
          "secret": true
        },
        "dotreadme.ai.model": {
          "type": "string",
          "default": "",
          "description": "Override the default AI model. Leave empty to use the recommended default (claude-sonnet-4-20250514 or gpt-4o)."
        }
      }
    },
    "commands": [
      {
        "command": "dotreadme.openSimulator",
        "title": "DotReadme: Open Simulator",
        "icon": "$(preview)"
      },
      {
        "command": "dotreadme.fixRelativePaths",
        "title": "DotReadme: Fix Relative Paths",
        "icon": "$(file-media)"
      },
      {
        "command": "dotreadme.insertBadge",
        "title": "DotReadme: Insert Badge",
        "icon": "$(shield)"
      },
      {
        "command": "dotreadme.auditReadme",
        "title": "Audit README Quality",
        "category": "DotReadme",
        "icon": "$(check)"
      },
      {
        "command": "dotreadme.rewriteForClarity",
        "title": "Rewrite for Clarity",
        "category": "DotReadme"
      },
      {
        "command": "dotreadme.rewriteForTone",
        "title": "Rewrite for Tone",
        "category": "DotReadme"
      },
      {
        "command": "dotreadme.generateMissingSection",
        "title": "Generate Missing Section",
        "category": "DotReadme"
      },
      {
        "command": "dotreadme.generateToc",
        "title": "Generate Table of Contents",
        "category": "DotReadme"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "dotreadme.openSimulator",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "dotreadme.auditReadme",
          "when": "resourceLangId == markdown",
          "group": "dotreadme_group@1"
        },
        {
          "command": "dotreadme.fixRelativePaths",
          "when": "resourceLangId == markdown",
          "group": "dotreadme_group@2"
        },
        {
          "command": "dotreadme.insertBadge",
          "when": "resourceLangId == markdown",
          "group": "dotreadme_group@3"
        },
        {
          "command": "dotreadme.generateToc",
          "group": "dotreadme_group@4",
          "when": "resourceLangId == markdown"
        },
        {
          "submenu": "dotreadme.aiSubmenu",
          "group": "dotreadme_group@4",
          "when": "resourceLangId == markdown"
        }
      ],
      "dotreadme.aiSubmenu": [
        {
          "command": "dotreadme.rewriteForClarity",
          "group": "1_rewrite@1",
          "when": "editorHasSelection && resourceLangId == markdown"
        },
        {
          "command": "dotreadme.rewriteForTone",
          "group": "1_rewrite@2",
          "when": "editorHasSelection && resourceLangId == markdown"
        },
        {
          "command": "dotreadme.generateMissingSection",
          "group": "2_generate@1",
          "when": "resourceLangId == markdown"
        }
      ]
    },
    "submenus": [
      {
        "id": "dotreadme.aiSubmenu",
        "label": "DotReadme AI"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dotreadme-sidebar",
          "title": "DotReadme",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "dotreadme-sidebar": [
        {
          "id": "dotreadme-view",
          "name": "Quick Actions",
          "icon": "$(tools)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "dotreadme-view",
        "contents": "Welcome to DotReadme! 🚀\nOptimize your documentation with one click.\n\n[$(check) Audit README Quality](command:dotreadme.auditReadme)\n\n[$(preview) Open Simulator](command:dotreadme.openSimulator)\n\n[$(file-media) Fix Relative Paths](command:dotreadme.fixRelativePaths)\n\n[$(shield) Insert Badge](command:dotreadme.insertBadge)\n\n[$(list-unordered) Generate TOC](command:dotreadme.generateToc)\n\n[$(sparkle) DotReadme AI](command:dotreadme.generateMissingSection)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.108.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.0",
    "eslint": "^9.39.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3"
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  }
}
